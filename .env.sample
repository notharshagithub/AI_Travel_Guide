# Copy this file to .env and fill in your keys. Vite will expose vars prefixed with VITE_

# Google OAuth (used by @react-oauth/google)
VITE_GOOGLE_AUTH_CLIENT_ID=

# Google Places API (used by GooglePlacesAutocomplete and Places REST calls)
VITE_GOOGLE_PLACE_API_KEY=

# Google Generative AI (Gemini) API
VITE_GOOGLE_GEMINI_AI_API_KEY=
# Optional: override the default model (defaults to gemini-2.5-flash)
VITE_GEMINI_MODEL=gemini-2.5-flash

# Firebase (use your own project values)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
